# =========================
# .NET / C# / Visual Studio
# =========================
## Ignore Visual Studio temporary files, build results, and user settings
.vs/
bin/
obj/
*.user
*.suo
*.userprefs

## Ignore environment-specific settings (Security Best Practice)
appsettings.Development.json
appsettings.Local.json

# =========================
# Next.js / Node / Frontend
# =========================
## Dependencies (NEVER commit this)
node_modules/

## Next.js build output
.next/
out/

## Production build output
build/
dist/

## Environment variables (Security Best Practice)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

## Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

